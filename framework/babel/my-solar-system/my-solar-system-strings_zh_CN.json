    "introScreen": {
      "screenSummary": {
        "playAreaDescription": {
          "value": "游戏区是一个观察窗口，显示一个包含两个天体的场景。可以实验调整两个天体的质量、速度、位置和方向。"
        },
        "controlAreaDescription": {
          "value": "在控制区中，有添加网格和卷尺的选项。你还可以切换天体的轨迹和数值的显示，以及查看它们的质心。控制区有用于控制观察窗口中动作速度的选项，包括暂停和逐步前进按钮。"
        }
      }
    },
    "labScreen": {
      "screenSummary": {
        "playAreaDescription": {
          "value": "游戏区是一个观察窗口，显示一个有多种选项的场景，可以设置自己的实验。重现我们的太阳和地球，或创建你自己的太阳系。"
        },
        "controlAreaDescription": {
          "value": "在控制区中，有查看和更改轨道区域的选项，以及调整和查看轨道信息的选项。你可以选择预设的天体排列或自定义，还有缩放选项。控制区有用于控制观察窗口中动作速度的选项，包括暂停和逐步前进按钮。"
        }
      },
